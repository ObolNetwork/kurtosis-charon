{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "github-actions",
    "custom.regex"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^deployments/env/.*\\.env$"
      ],
      "matchStrings": [
        "(?:CL|VC|EL|CHARON)_IMAGE=(?<depName>[^\\n]+)\\n(?:CL|VC|EL|CHARON)_VERSION=(?<currentValue>[^\\n]+)"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchDepTypes": [
        "github-actions"
      ],
      "matchFileNames": [
        ".github/workflows/**"
      ],
      "schedule": [
        "every weekend"
      ],
      "labels": [
        "renovate/github-actions"
      ],
      "groupName": "GitHub Actions updates"
    },
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchFileNames": [
        "deployments/env/**"
      ],
      "labels": [
        "renovate/docker-deps"
      ],
      "groupName": "Docker image updates",
      "schedule": [
        "at any time"
      ]
    },
    {
      "matchPackageNames": [
        "statusim/nimbus-eth2",
        "statusim/nimbus-validator-client"
      ],
      "versioning": "regex:^multiarch-v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    }
  ]
}